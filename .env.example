# Copia este archivo como .env y rellena los valores con tus credenciales reales.
# IMPORTANTE: nunca subas el archivo .env al repositorio (esta en .gitignore).

# ----------------------------------------------------------------------
# Identidad del equipo
# ----------------------------------------------------------------------
TEAM_ID=tu_equipo

# ----------------------------------------------------------------------
# Endpoints Aruba (corporativos)
# ----------------------------------------------------------------------
ARUBA_INVENTORY_API=http://10.10.48.30:8080
ARUBA_TEAM_API=http://10.10.48.21:8080

# ----------------------------------------------------------------------
# OSRM (motor de rutas por carretera)
#   - Por defecto usa el servidor publico de demostracion. Si tienes uno
#     local apuntalo aqui (p.ej. http://10.10.48.30:5000)
#   - Si no hay conectividad, las rutas caen al grafo del inventory y
#     finalmente a linea recta entre landmarks.
# ----------------------------------------------------------------------
OSRM_URL=https://router.project-osrm.org
OSRM_PROFILE=driving
OSRM_TIMEOUT=6

# ----------------------------------------------------------------------
# Kafka
# ----------------------------------------------------------------------
KAFKA_BROKER=10.10.48.30:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=
KAFKA_TOPIC_TELEMETRIA=aruba.team.tu_equipo
KAFKA_TOPIC_CLIMA=aruba.weather
KAFKA_TOPIC_EVENTOS=aruba.events
# Control de offset inicial por consumidor (earliest|latest)
KAFKA_OFFSET_CLIMA=latest
KAFKA_OFFSET_EVENTOS=earliest

# ----------------------------------------------------------------------
# LLM (Qwen / Gemma compatible OpenAI)
# ----------------------------------------------------------------------
LLM_BASE_URL=http://10.10.48.10:8001/v1
LLM_API_KEY=dummy
LLM_MODEL=Qwen/Qwen3-235B-A22B
LLM_TEMPERATURA=0.6
LLM_TOP_P=0.95
LLM_MAX_TOKENS=1024
LLM_THINKING=false

# ----------------------------------------------------------------------
# Servidor Flask / Socket.IO
# ----------------------------------------------------------------------
HOST_SERVIDOR=0.0.0.0
PUERTO_SERVIDOR=8080
FLASK_DEBUG=false
# FLASK_SECRET_KEY=genera_una_cadena_aleatoria_larga

# ----------------------------------------------------------------------
# Simulacion
# ----------------------------------------------------------------------
INTERVALO_SIM=0.5
INTERVALO_TELEMETRIA=7.5
VELOCIDAD_PATRULLA=35

# ----------------------------------------------------------------------
# Limites geograficos de Aruba (no tocar normalmente)
# ----------------------------------------------------------------------
ARUBA_LAT_MIN=12.4
ARUBA_LAT_MAX=12.7
ARUBA_LON_MIN=-70.1
ARUBA_LON_MAX=-69.8

# ----------------------------------------------------------------------
# Seguridad
# ----------------------------------------------------------------------
# CORS_ORIGENES=https://tu_dominio.com,https://otro.com  (o * para abrir)
# CORS_ORIGENES=*
TIEMPO_SESION=3600
