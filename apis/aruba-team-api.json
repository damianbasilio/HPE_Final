              ],
              "description": "Center longitude for proximity filter",
              "title": "Near Lon"
            },
            "description": "Center longitude for proximity filter"
          },
          {
            "name": "radius_km",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "maximum": 100,
              "exclusiveMinimum": 0,
              "description": "Search radius in km (requires near_lat + near_lon)",
              "default": 5,
              "title": "Radius Km"
            },
            "description": "Search radius in km (requires near_lat + near_lon)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 20,
              "minimum": 1,
              "description": "Max items per page",
              "default": 20,
              "title": "Limit"
            },
            "description": "Max items per page"
          },
          {
            "name": "offset",
